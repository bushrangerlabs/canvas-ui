  /**
   * Send a chat message to the AI agent
   * Phase 4.6: Three-stage universal pipeline (ALWAYS runs):
   * - Stage 1: Interpret intent (Phi3)
   * - Stage 2: Create plan (Llama3)
   * - Stage 3: Generate code (CodeLlama)
   * 
   * @param text - User's message
   * @param agentId - AI agent to use (fallback if no multi-model config)
   * @param conversationId - Optional conversation ID for context
   * @returns AI's response with metadata
   */
  async sendMessage(
    text: string,
    _agentId?: string, // Kept for API compatibility, not used in three-stage pipeline
    conversationId?: string
  ): Promise<AIResponse> {
    try {
      // Add user message to history
      this.conversationHistory.push({
        role: 'user',
        content: text,
        timestamp: Date.now()
      });

      // THREE-STAGE UNIVERSAL PIPELINE (Phase 4.6)
      // Always runs for EVERY request (no keyword matching)
      console.log('[AI] Starting three-stage pipeline');
      
      // STAGE 1: Interpret user intent (Phi3 - fast)
      const interpretation = await this.interpretIntent(
        text,
        this.lastCanvasState,
        conversationId
      );
      console.log('[AI] Stage 1 complete - Intent:', interpretation.substring(0, 100) + '...');
      
      // STAGE 2: Create strategic plan (Llama3 - smart)
      const plan = await this.createPlan(
        interpretation,
        this.lastCanvasState,
        conversationId
      );
      console.log('[AI] Stage 2 complete - Plan:', plan.substring(0, 100) + '...');
      
      // STAGE 3: Generate executable code (CodeLlama - specialized)
      const code = await this.generateCodeFromPlan(plan, conversationId);
      console.log('[AI] Stage 3 complete - Code ready for execution');
      
      // Store combined response in history
      const fullResponse = `${interpretation}\n\n${plan}`;
      this.conversationHistory.push({
        role: 'assistant',
        content: fullResponse,
        timestamp: Date.now(),
        isCode: true
      });
      
      return {
        text: fullResponse,
        code: code,
        hasCode: true,
        conversationId
      };
      
    } catch (error: unknown) {
      console.error('[AI] Three-stage pipeline failed:', error);
      throw new Error((error as Error)?.message || 'Failed to process request');
    }
  }

  /**
   * Select model for task based on multi-model config (Phase 4.5)
   * 
   * @param task - Task type: 'planning', 'code', or 'refinement'
   * @param fallbackAgent - User-selected agent from UI (fallback if no config)
   * @returns Agent ID to use for this task
   */
  private selectModelForTask(
    task: 'planning' | 'code' | 'refinement',
    fallbackAgent?: string
  ): string | undefined {
    // No multi-model config: use fallback agent
    if (!this.config || !this.config.useMultiModel) {
      return fallbackAgent || this.config?.models.fallback;
    }

    // Select model based on strategy and task
    switch (this.config.strategy) {
      case 'triple':
        // Use specialized model for each task
        switch (task) {
          case 'planning':
            return this.config.models.planning || this.config.models.fallback;
          case 'code':
            return this.config.models.code || this.config.models.fallback;
          case 'refinement':
            return this.config.models.refinement || this.config.models.fallback;
        }
        break;

      case 'dual':
        // Use fast model for refinement, main model for planning/code
        if (task === 'refinement') {
          return this.config.models.refinement || this.config.models.fallback;
        }
        return this.config.models.planning || this.config.models.fallback;

      case 'single':
      case 'custom':
      default:
        // Single model for all tasks
        return this.config.models.fallback;
    }

    return fallbackAgent || this.config.models.fallback;
  }

  /**
   * Call AI with given prompt
   * Uses longer timeout (60s default, 120s for code generation) since AI can be slow
   */
  private async callAI(
    text: string,
    agentId?: string,
    conversationId?: string,
    timeoutMs: number = 60000
  ): Promise<AIResponse> {
    try {
      // Build service data - only include agent_id if provided
      const serviceData: any = {
        text: text,
        language: 'en',
      };
      
      if (agentId) {
        serviceData.agent_id = agentId;
      }
      
      if (conversationId) {
        serviceData.conversation_id = conversationId;
      }
      
      console.log('Sending message via WebSocket:', { text: text.substring(0, 200) + '...' });
      
      // Use raw WebSocket message (like getAvailableAgents)
      // callService doesn't return the AI response, only context metadata
      if (!this.hass.sendMessage) {
        throw new Error('WebSocket sendMessage not available');
      }
      
      // Wrap with custom timeout (configurable, default 60s)
      const response = await this.sendMessageWithTimeout(
        {
          type: 'conversation/process',
          ...serviceData,
        },
        timeoutMs
      );
      
      console.log('Conversation response:', response);
      
      // Handle WebSocket wrapper structure
      const result = (response as any)?.result || response;
      
      // Try multiple possible paths for the speech text
      const speech = 
        result?.response?.speech?.plain?.speech ||  // Standard HA path
        result?.speech?.plain?.speech ||  // Direct speech
        result?.text ||  // Simple text field
        result?.message ||  // Message field
        response?.response?.speech?.plain?.speech ||  // Top-level response
        response?.text ||  // Top-level text
        response?.message;  // Top-level message
      
      console.log('Extracted speech:', speech);
      
      if (!speech) {
        console.warn('Could not extract speech. Full result:', JSON.stringify(result, null, 2));
        throw new Error('No response from AI');
      }

      // Extract conversation ID for context
      const newConversationId = result?.conversation_id || (response as any)?.conversation_id;

      // Check if response contains code
      const hasCode = /```(?:javascript|js)?\n[\s\S]*?\n```/.test(speech);
      
      // Extract and validate code if present
      let extractedCode: string | undefined;
      if (hasCode) {
        extractedCode = this.extractCode(speech);
        
        // Validate extracted code syntax
        if (extractedCode) {
          // Check for Python code first
          if (/\b(import|from|datetime|def |class |print\()/i.test(extractedCode)) {
            console.error('[AI] ❌ Code is Python, not JavaScript');
            console.error('[AI] Problematic code:', extractedCode.substring(0, 200));
            throw new Error('AI generated Python code instead of JavaScript - must use JavaScript with const/let, not import statements');
          }

          // Check for placeholders (before syntax check)
          if (/\[\.\.\.\]|\bfunction\s*\(\.\.\.\)|gridLayout\(\s*\[\.\.\.\]/.test(extractedCode)) {
            console.error('[AI] ❌ Code contains placeholders ([...] or ...)');
            console.error('[AI] Problematic code:', extractedCode);
            throw new Error('AI generated incomplete code with placeholders like [...] or ... - code must be COMPLETE and executable');
          }

          try {
            // Quick syntax check - try to parse as JavaScript
            new Function(extractedCode);
            console.log('[AI] ✅ Code syntax validation passed');
          } catch (syntaxError) {
            console.error('[AI] ❌ Invalid JavaScript syntax:', syntaxError);
            console.error('[AI] Problematic code:', extractedCode);
            throw new Error(`AI generated invalid JavaScript: ${(syntaxError as Error).message}`);
          }
        } else {
          console.warn('[AI] Code block found but extraction failed (likely contains planning text)');
          throw new Error('AI response contained code blocks but no clean executable code. The code may have planning comments like [Generated code] or [CurState] mixed in.');
        }
      }

      return {
        text: speech,
        conversationId: newConversationId,
        hasCode,
        code: extractedCode,
      };
    } catch (error: unknown) {
      console.error('Failed to send message to AI:', error);
      throw new Error((error as Error)?.message || 'Failed to communicate with AI');
    }
  }

  /**
   * Extract code from markdown code blocks
   */
  private extractCode(text: string): string | undefined {
    // Extract ALL code blocks, then find the best one
    const codeBlockRegex = /```(?:javascript|js)?\n([\s\S]*?)\n```/g;
    const matches = [...text.matchAll(codeBlockRegex)];
    
    if (matches.length === 0) {
      return undefined;
    }

    // Find the cleanest code block (no planning markers, actual canvasAPI calls)
    const cleanBlocks = matches
      .map(match => match[1].trim())
      .filter(code => {
        // Filter out blocks with planning text markers
        const hasPlanningMarkers = /\[Generated code\]|\[CurState\]|\[Plan extension\]|\[Updated code\]|\[INITIAL PLAN\]/i.test(code);
        if (hasPlanningMarkers) {
          console.warn('[extractCode] Skipping block with planning markers:', code.substring(0, 100));
          return false;
        }

        // Filter out blocks with placeholder syntax like [...] or ...
        const hasPlaceholders = /\[\.\.\.\]|\bfunction\s*\(\.\.\.\)|gridLayout\(\s*\[\.\.\.\]/.test(code);
        if (hasPlaceholders) {
          console.warn('[extractCode] Skipping block with placeholders ([...] or ...):', code.substring(0, 100));
          return false;
        }

        // Filter out Python code (import, from, datetime, def, etc.)
        const isPython = /\b(import|from|datetime|def |class |print\(|if __name__)/i.test(code);
        if (isPython) {
          console.warn('[extractCode] Skipping Python code block:', code.substring(0, 100));
          return false;
        }

        // Must contain at least one canvasAPI call
        const hasCanvasAPI = /canvasAPI\.(addWidget|updateWidget|deleteWidget|gridLayout)/.test(code);
        if (!hasCanvasAPI) {
          console.warn('[extractCode] Skipping block without canvasAPI calls:', code.substring(0, 100));
          return false;
        }

        return true;
      });

    if (cleanBlocks.length === 0) {
      console.error('[extractCode] No clean code blocks found. All blocks contained planning text or no canvasAPI calls.');
      return undefined;
    }

    // Return the longest clean block (likely the most complete)
    const bestBlock = cleanBlocks.reduce((longest, current) => 
      current.length > longest.length ? current : longest
    );

    console.log(`[extractCode] Selected best block (${bestBlock.length} chars) from ${matches.length} total blocks`);
    return bestBlock;
  }

  /**
   * Extract conversation ID from response (for follow-up messages)
   */
  extractConversationId(response: unknown): string | undefined {
    return (response as { conversation_id?: string })?.conversation_id;
  }
}
