  // ============================================================================
  // PROMPT MODE METHODS (User-Guided Creation)
  // ============================================================================

  /**
   * Create widgets using Prompt Mode - user approves at each step
   * User approves: understanding → widget list → each widget config
   */
  async createWidgetsPromptMode(
    userPrompt: string,
    onProgress?: (update: { stage: string; message: string }) => void,
    onUserApproval?: (data: { stage: string; content: any }) => Promise<boolean | string>,
    onWidgetCreated?: (widget: any) => Promise<void>
  ): Promise<PipelineResult> {
    console.log('[Prompt Mode] Starting user-guided widget creation...');
    
    try {
      // Create new abort controller for this execution
      this.abortController = new AbortController();

      // STAGE 1: Understanding + user confirmation
      onProgress?.({ stage: 'understanding', message: 'Understanding your request...' });
      
      const requestType = (this.lastCanvasState?.widgetCount || 0) === 0 ? 'new' : 'edit';
      let stage1Result = await this.stage1_understand(userPrompt, requestType);
      
      // Show understanding to user for approval (with retry loop for feedback)
      let understandingApproval = await onUserApproval?.({
        stage: 'understanding',
        content: stage1Result
      });
      
      // If user provided feedback (string), revise understanding
      while (typeof understandingApproval === 'string') {
        console.log('[Prompt Mode] User feedback on understanding:', understandingApproval);
        const revisedPrompt = `${userPrompt}\n\nUser clarification: ${understandingApproval}`;
        stage1Result = await this.stage1_understand(revisedPrompt, requestType);
        
        understandingApproval = await onUserApproval?.({
          stage: 'understanding',
          content: stage1Result
        });
      }
      
      if (!understandingApproval) {
        return { success: false, error: 'User cancelled' };
      }

      // STAGE 2: Generate widget list (not full configs)
      onProgress?.({ stage: 'planning', message: 'Creating widget list...' });
      
      let widgetList = await this.stage2GenerateWidgetList(stage1Result);
      
      // Show widget list to user for approval (with retry loop for feedback)
      let widgetListApproval = await onUserApproval?.({
        stage: 'widget_list',
        content: widgetList
      });
      
      // If user provided feedback (string), revise widget list
      while (typeof widgetListApproval === 'string') {
        console.log('[Prompt Mode] User feedback on widget list:', widgetListApproval);
        
        const revisionPrompt = `Revise this widget list based on user feedback:

Current plan: ${JSON.stringify(widgetList.widgets, null, 2)}

User feedback: ${widgetListApproval}

Output revised widget list in same JSON format.`;
        
        const revisionResponse = await this.callAI(revisionPrompt, 30000);
        
        // Clean response FIRST (removes markdown code blocks)
        const cleanedResponse = this.cleanJSON(revisionResponse);
        console.log('[Widget List Revision] Cleaned response:', cleanedResponse);
        
        // THEN extract JSON
        const jsonMatch = cleanedResponse.match(/\{[\s\S]*\}/);
        if (jsonMatch) {
          const revisedData = JSON.parse(jsonMatch[0]);
          console.log('[Widget List Revision] Parsed data:', revisedData);
          
          // Update with revised data
          widgetList = {
            understanding: revisedData.understanding || widgetList.understanding,
            widgets: revisedData.widgets || widgetList.widgets,
            totalCount: revisedData.widgets?.length || widgetList.totalCount
          };
          
          console.log('[Widget List Revision] Updated widgetList:', widgetList);
        } else {
          console.error('[Widget List Revision] Failed to extract JSON from cleaned response:', cleanedResponse);
        }
        
        widgetListApproval = await onUserApproval?.({
          stage: 'widget_list',
          content: widgetList
        });
      }
      
      if (!widgetListApproval) {
        return { success: false, error: 'User cancelled' };
      }

      // STAGE 3: Create each widget with user approval
      const createdWidgets: any[] = [];
      
      for (let i = 0; i < widgetList.widgets.length; i++) {
        const widgetPlan = widgetList.widgets[i];
        
        onProgress?.({ 
          stage: 'creating', 
          message: `Creating widget ${i + 1}/${widgetList.widgets.length}...` 
        });
        
        // Generate config for ONE widget
        let widgetConfig = await this.generateWidgetConfig(widgetPlan, i, widgetList.widgets.length);
        
        // Show config to user for approval/tweaks (with retry loop for feedback)
        let configApproval = await onUserApproval?.({
          stage: 'widget_config',
          content: { 
            widgetNumber: i + 1,
            totalWidgets: widgetList.widgets.length,
            config: widgetConfig
          }
        });
        
        // If user provided feedback (string), revise widget config
        while (typeof configApproval === 'string') {
          console.log(`[Prompt Mode] User feedback on widget ${i + 1}:`, configApproval);
          
          const revisionPrompt = `Revise this widget configuration based on user feedback:

Current config: ${JSON.stringify(widgetConfig, null, 2)}

User feedback: ${configApproval}

Output revised config in same JSON format.`;
          
          const revisionResponse = await this.callAI(revisionPrompt, 20000);
          
          // Clean response FIRST (removes markdown code blocks)
          const cleanedResponse = this.cleanJSON(revisionResponse);
          console.log(`[Widget ${i + 1} Revision] Cleaned response:`, cleanedResponse);
          
          // THEN extract JSON
          const jsonMatch = cleanedResponse.match(/\{[\s\S]*\}/);
          if (jsonMatch) {
            widgetConfig = JSON.parse(jsonMatch[0]);
            console.log(`[Widget ${i + 1} Revision] Updated config:`, widgetConfig);
          } else {
            console.error(`[Widget ${i + 1} Revision] Failed to extract JSON from cleaned response:`, cleanedResponse);
          }
          
          configApproval = await onUserApproval?.({
            stage: 'widget_config',
            content: { 
              widgetNumber: i + 1,
              totalWidgets: widgetList.widgets.length,
              config: widgetConfig
            }
          });
        }
        
        if (!configApproval) {
          console.log(`[Prompt Mode] User rejected widget ${i + 1}, skipping...`);
          continue;
        }
        
        // Transform AI's simplified config to proper Canvas UI widget format
        const transformedWidget = this.transformToCanvasWidget(widgetConfig);
        
        // Create widget immediately
        createdWidgets.push(transformedWidget);
        await onWidgetCreated?.(transformedWidget);
        
        console.log(`[Prompt Mode] Widget ${i + 1}/${widgetList.widgets.length} created ✓`);
      }

      return {
        success: true,
        widgetCount: createdWidgets.length,
        stage1Understanding: stage1Result,
        totalAttempts: 1
      };
      
    } catch (error) {
      console.error('[Prompt Mode] Error:', error);
      return {
        success: false,
        error: error instanceof Error ? error.message : 'Unknown error'
      };
    }
  }

  /**
   * Helper: Clean and fix common JSON issues from AI responses
   */
  private cleanJSON(jsonString: string): string {
    // Remove markdown code blocks
    let cleaned = jsonString.replace(/```json\s*/g, '').replace(/```\s*/g, '');
    
    // Remove JavaScript-style comments (AI sometimes adds these)
    // Remove single-line comments: // comment
    cleaned = cleaned.replace(/\/\/[^\n]*/g, '');
    // Remove multi-line comments: /* comment */
    cleaned = cleaned.replace(/\/\*[\s\S]*?\*\//g, '');
    
    // Replace single quotes with double quotes (common AI mistake)
    cleaned = cleaned.replace(/'/g, '"');
    
    // Fix unquoted property names (another common mistake)
    cleaned = cleaned.replace(/([{,]\s*)([a-zA-Z_][a-zA-Z0-9_]*)\s*:/g, '$1"$2":');
    
    return cleaned.trim();
  }

  /**
   * STAGE 2 (Prompt Mode): Generate widget list only (not full configs)
   */
  private async stage2GenerateWidgetList(
    stage1Understanding: Stage1Output
  ): Promise<WidgetListPlan> {
    console.log('[Stage 2 - Prompt Mode] Generating widget list...');
    
    // Build simplified prompt for widget list only
    const prompt = `Based on this understanding:
${JSON.stringify(stage1Understanding, null, 2)}

Create a simple list of widgets needed. For each widget, specify:
- type: Widget type (MUST be one of: button, text, gauge, slider, switch, image, icon, progressbar, progresscircle, inputtext, flipclock, digitalclock, knob, iframe, border, value, radiobutton, colorpicker, weather, graph, calendar, scrollingtext, keyboard, camera, lovelacecard, html, resolution)
- purpose: What this widget does
- label: User-facing label (optional)
- entity: Entity ID if relevant (optional)

IMPORTANT: For border/container widgets, use type "border" (not "container")

Output JSON format:
{
  "understanding": "Brief summary of what you're creating",
  "widgets": [
    {"type": "button", "purpose": "Turn on ceiling light", "label": "Ceiling", "entity": "light.bedroom_ceiling"},
    {"type": "slider", "purpose": "Control brightness", "label": "Brightness", "entity": "light.bedroom_ceiling"}
  ]
}`;

    const response = await this.callAI(prompt, 30000);
    
    // Extract JSON from response
    const jsonMatch = response.match(/\{[\s\S]*\}/);
    if (!jsonMatch) {
      throw new Error('Failed to extract widget list JSON from AI response');
    }
    
    // Clean and parse JSON
    const cleanedJSON = this.cleanJSON(jsonMatch[0]);
    console.log('[Stage 2] Cleaned JSON:', cleanedJSON);
    const widgetListData = JSON.parse(cleanedJSON);
    
    return {
      understanding: widgetListData.understanding || stage1Understanding.userIntent,
      widgets: widgetListData.widgets || [],
      totalCount: widgetListData.widgets?.length || 0
    };
  }

  /**
   * Generate configuration for ONE widget (Prompt Mode)
   */
  /**
   * Transform AI's simplified config to proper Canvas UI widget format
   */
  private transformToCanvasWidget(aiConfig: any): any {
    const widgetType = aiConfig.type === 'container' ? 'border' : aiConfig.type; // Map container → border
    
    // Extract position and size
    const position = aiConfig.position || { x: 10, y: 10 };
    const size = aiConfig.size || { width: 100, height: 50 };
    
    // Build proper Canvas UI widget structure
    const canvasWidget: any = {
      id: aiConfig.id || `widget-${Date.now()}-${Math.random().toString(36).substring(2, 11)}`,
      type: widgetType,
      config: {},
      position: {
        x: position.x,
        y: position.y,
        width: size.width,
        height: size.height
      }
    };
    
    // Widget-specific config transformation
    switch (widgetType) {
      case 'border':
        canvasWidget.config = {
          borderWidth: aiConfig.borderWidth || aiConfig.thickness || 2,
          borderColor: aiConfig.borderColor || aiConfig.color || '#ffffff',
          borderStyle: aiConfig.borderStyle || aiConfig.style || 'solid',
          borderRadius: aiConfig.borderRadius ?? 0
        };
        break;
        
      case 'button':
        canvasWidget.config = {
          label: aiConfig.label || 'Button',
          entity_id: aiConfig.entity_id || '',
          backgroundColor: aiConfig.color || '#3b82f6',
          textColor: '#ffffff',
          action: 'toggle',
          showIcon: aiConfig.icon ? true : false,
          iconName: aiConfig.icon || 'PowerSettingsNew'
        };
        break;
        
      case 'text':
        canvasWidget.config = {
          text: aiConfig.label || aiConfig.text || 'Text',
          entity_id: aiConfig.entity_id || '',
          fontSize: aiConfig.fontSize || 16,
          fontWeight: 'normal',
          textAlign: 'center',
          color: aiConfig.color || '#ffffff'
        };
        break;
        
      case 'slider':
        canvasWidget.config = {
          entity_id: aiConfig.entity_id || '',
          attribute: aiConfig.attribute || 'brightness',
          min: aiConfig.min || 0,
          max: aiConfig.max || 255,
          step: aiConfig.step || 1,
          orientation: 'horizontal',
          showValue: true,
          color: aiConfig.color || '#3b82f6'
        };
        break;
        
      case 'value':
        canvasWidget.config = {
          entity_id: aiConfig.entity_id || '',
          label: aiConfig.label || '',
          fontSize: aiConfig.fontSize || 24,
          showIcon: aiConfig.icon ? true : false,
          iconName: aiConfig.icon || '',
          color: aiConfig.color || '#ffffff'
        };
        break;
        
      default:
        // Generic fallback - copy all AI config fields
        canvasWidget.config = {
          label: aiConfig.label || '',
          entity_id: aiConfig.entity_id || '',
          color: aiConfig.color || '#ffffff',
          ...aiConfig
        };
        break;
    }
    
    console.log('[Transform] AI config → Canvas widget:', { aiConfig, canvasWidget });
    return canvasWidget;
  }

  private async generateWidgetConfig(
    widgetPlan: WidgetPlan,
    index: number,
    totalCount: number
  ): Promise<any> {
    console.log(`[Widget Config] Generating config for widget ${index + 1}/${totalCount}...`);
    
    // Map container to border
    const widgetType = widgetPlan.type === 'container' ? 'border' : widgetPlan.type;
    
    const prompt = `Create configuration for this widget:

Widget Plan:
- Type: ${widgetType}
- Purpose: ${widgetPlan.purpose}
- Label: ${widgetPlan.label || 'auto-generate'}
- Entity: ${widgetPlan.entity || 'none'}

Generate a complete config with these fields:
- label: User-facing label 
- color: Hex color code (choose appropriate for purpose)
- icon: Icon name (optional, based on purpose)
- size: {width: number, height: number}
- position: {x: ${index * 120 + 10}, y: 10} (simple grid placement)

Output JSON format:
{
  "type": "${widgetType}",
  "label": "...",
  "color": "#xxxxxx",
  "icon": "...",
  "entity_id": "${widgetPlan.entity || ''}",
  "size": {"width": 100, "height": 50},
  "position": {"x": ${index * 120 + 10}, "y": 10}
}`;

    const response = await this.callAI(prompt, 20000);
    
    // Extract JSON
    const jsonMatch = response.match(/\{[\s\S]*\}/);
    if (!jsonMatch) {
      throw new Error('Failed to extract widget config JSON');
    }
    
    // Clean and parse JSON
    const cleanedJSON = this.cleanJSON(jsonMatch[0]);
    console.log('[Widget Config] Cleaned JSON:', cleanedJSON);
    return JSON.parse(cleanedJSON);
  }
}
