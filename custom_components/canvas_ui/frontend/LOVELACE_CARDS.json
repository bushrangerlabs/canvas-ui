{
  "cards": {
    "custom:mushroom-entity-card": {
      "name": "Mushroom Entity Card",
      "description": "Generic entity card with icon and state",
      "domains": ["*"],
      "keywords": ["mushroom", "entity", "generic"],
      "example": {
        "type": "custom:mushroom-entity-card",
        "entity": "light.living_room",
        "name": "Living Room",
        "icon": "mdi:lightbulb",
        "tap_action": {
          "action": "toggle"
        }
      },
      "schema": {
        "entity": "required - Entity ID",
        "name": "optional - Display name",
        "icon": "optional - MDI icon",
        "icon_color": "optional - Icon color (e.g., red, blue, amber)",
        "tap_action": "optional - Action on tap",
        "hold_action": "optional - Action on hold",
        "double_tap_action": "optional - Action on double tap"
      }
    },
    "custom:mushroom-light-card": {
      "name": "Mushroom Light Card",
      "description": "Light control with color picker and brightness slider",
      "domains": ["light"],
      "keywords": ["mushroom", "light", "brightness", "color"],
      "example": {
        "type": "custom:mushroom-light-card",
        "entity": "light.living_room",
        "name": "Living Room",
        "icon": "mdi:lightbulb",
        "use_light_color": true,
        "show_brightness_control": true,
        "show_color_control": true,
        "collapsible_controls": true
      },
      "schema": {
        "entity": "required - Light entity",
        "name": "optional - Display name",
        "icon": "optional - MDI icon",
        "use_light_color": "optional - Use light's color for icon (default: false)",
        "show_brightness_control": "optional - Show brightness slider (default: true)",
        "show_color_control": "optional - Show color picker (default: true)",
        "show_color_temp_control": "optional - Show color temperature control (default: true)",
        "collapsible_controls": "optional - Collapsible controls (default: true)"
      }
    },
    "custom:mushroom-fan-card": {
      "name": "Mushroom Fan Card",
      "description": "Fan control with speed and oscillation",
      "domains": ["fan"],
      "keywords": ["mushroom", "fan", "speed", "oscillate"],
      "example": {
        "type": "custom:mushroom-fan-card",
        "entity": "fan.bedroom",
        "name": "Bedroom Fan",
        "icon": "mdi:fan",
        "show_percentage_control": true,
        "show_oscillate_control": true,
        "collapsible_controls": true
      },
      "schema": {
        "entity": "required - Fan entity",
        "name": "optional - Display name",
        "icon": "optional - MDI icon",
        "icon_color": "optional - Icon color",
        "show_percentage_control": "optional - Show speed percentage (default: true)",
        "show_oscillate_control": "optional - Show oscillation toggle (default: true)",
        "collapsible_controls": "optional - Collapsible controls (default: true)"
      }
    },
    "custom:mushroom-climate-card": {
      "name": "Mushroom Climate Card",
      "description": "Climate/thermostat control",
      "domains": ["climate"],
      "keywords": ["mushroom", "climate", "thermostat", "hvac", "temperature"],
      "example": {
        "type": "custom:mushroom-climate-card",
        "entity": "climate.living_room",
        "name": "Living Room Climate",
        "icon": "mdi:thermostat",
        "show_temperature_control": true,
        "collapsible_controls": true
      },
      "schema": {
        "entity": "required - Climate entity",
        "name": "optional - Display name",
        "icon": "optional - MDI icon",
        "show_temperature_control": "optional - Show temperature control (default: true)",
        "hvac_modes": "optional - List of HVAC modes to show",
        "collapsible_controls": "optional - Collapsible controls (default: true)"
      }
    },
    "custom:mushroom-cover-card": {
      "name": "Mushroom Cover Card",
      "description": "Cover/blind control with position",
      "domains": ["cover"],
      "keywords": ["mushroom", "cover", "blind", "shade", "curtain"],
      "example": {
        "type": "custom:mushroom-cover-card",
        "entity": "cover.living_room_blinds",
        "name": "Living Room Blinds",
        "icon": "mdi:blinds",
        "show_position_control": true,
        "show_tilt_position_control": false
      },
      "schema": {
        "entity": "required - Cover entity",
        "name": "optional - Display name",
        "icon": "optional - MDI icon",
        "show_position_control": "optional - Show position slider (default: true)",
        "show_tilt_position_control": "optional - Show tilt control (default: true)",
        "show_buttons_control": "optional - Show open/close buttons (default: true)"
      }
    },
    "custom:mushroom-person-card": {
      "name": "Mushroom Person Card",
      "description": "Person location and status",
      "domains": ["person", "device_tracker"],
      "keywords": ["mushroom", "person", "presence", "location", "tracker"],
      "example": {
        "type": "custom:mushroom-person-card",
        "entity": "person.john",
        "name": "John",
        "icon": "mdi:account",
        "use_entity_picture": true
      },
      "schema": {
        "entity": "required - Person or device_tracker entity",
        "name": "optional - Display name",
        "icon": "optional - MDI icon",
        "use_entity_picture": "optional - Use entity picture (default: true)",
        "icon_color": "optional - Icon color"
      }
    },
    "custom:button-card": {
      "name": "Button Card",
      "description": "Highly customizable button with templates and styles",
      "domains": ["*"],
      "keywords": ["button", "custom", "template", "style"],
      "example": {
        "type": "custom:button-card",
        "entity": "light.bedroom",
        "name": "Bedroom Light",
        "icon": "mdi:lightbulb",
        "show_state": true,
        "show_name": true,
        "tap_action": {
          "action": "toggle"
        },
        "styles": {
          "card": [
            {
              "background-color": "var(--primary-color)"
            }
          ]
        }
      },
      "schema": {
        "entity": "optional - Entity ID",
        "name": "optional - Button name",
        "icon": "optional - MDI icon",
        "show_state": "optional - Show entity state (default: false)",
        "show_name": "optional - Show button name (default: true)",
        "show_icon": "optional - Show icon (default: true)",
        "show_label": "optional - Show label (default: false)",
        "tap_action": "optional - Action on tap",
        "hold_action": "optional - Action on hold",
        "styles": "optional - Custom CSS styles object",
        "color": "optional - Icon/text color",
        "size": "optional - Button size (default: 40%)",
        "color_type": "optional - Color type (icon, card, label-card, blank-card)"
      }
    },
    "custom:mini-graph-card": {
      "name": "Mini Graph Card",
      "description": "Line/bar graphs for sensors with history",
      "domains": ["sensor", "binary_sensor"],
      "keywords": ["graph", "chart", "history", "sensor", "mini"],
      "example": {
        "type": "custom:mini-graph-card",
        "entities": ["sensor.temperature"],
        "name": "Temperature",
        "hours_to_show": 24,
        "points_per_hour": 2,
        "line_width": 2,
        "show": {
          "labels": true,
          "points": false,
          "legend": false
        }
      },
      "schema": {
        "entities": "required - Array of sensor entities",
        "name": "optional - Graph title",
        "hours_to_show": "optional - Hours of history (default: 24)",
        "points_per_hour": "optional - Data points per hour (default: 1)",
        "line_width": "optional - Line thickness (default: 5)",
        "line_color": "optional - Line color",
        "show": "optional - Object with labels, points, legend booleans",
        "animate": "optional - Animate line drawing (default: false)",
        "smoothing": "optional - Line smoothing (default: true)"
      }
    },
    "custom:vertical-stack-in-card": {
      "name": "Vertical Stack in Card",
      "description": "Stack multiple cards vertically with card styling",
      "domains": ["*"],
      "keywords": ["stack", "vertical", "container", "group"],
      "example": {
        "type": "custom:vertical-stack-in-card",
        "cards": [
          {
            "type": "entities",
            "entities": ["light.living_room"]
          },
          {
            "type": "entities",
            "entities": ["light.bedroom"]
          }
        ]
      },
      "schema": {
        "cards": "required - Array of card objects to stack",
        "title": "optional - Card title",
        "horizontal": "optional - Horizontal mode (default: false)"
      }
    },
    "custom:apexcharts-card": {
      "name": "ApexCharts Card",
      "description": "Advanced charting with multiple series and chart types",
      "domains": ["sensor", "binary_sensor"],
      "keywords": ["chart", "graph", "apex", "series", "advanced"],
      "example": {
        "type": "custom:apexcharts-card",
        "series": [
          {
            "entity": "sensor.temperature",
            "name": "Temperature"
          }
        ],
        "header": {
          "show": true,
          "title": "Temperature Chart"
        },
        "graph_span": "24h"
      },
      "schema": {
        "series": "required - Array of series objects with entity and name",
        "header": "optional - Header configuration object",
        "graph_span": "optional - Time span (1h, 24h, 7d, etc.)",
        "span": "optional - Alternative to graph_span",
        "chart_type": "optional - Chart type (line, area, bar, etc.)",
        "apex_config": "optional - Advanced ApexCharts configuration"
      }
    },
    "entities": {
      "name": "Entities Card (Native)",
      "description": "Built-in card for listing multiple entities",
      "domains": ["*"],
      "keywords": ["entities", "list", "native", "builtin"],
      "example": {
        "type": "entities",
        "title": "Living Room",
        "entities": ["light.living_room", "sensor.temperature", "switch.fan"]
      },
      "schema": {
        "entities": "required - Array of entity IDs",
        "title": "optional - Card title",
        "show_header_toggle": "optional - Show toggle all button (default: true)",
        "state_color": "optional - Color entities by state (default: true)"
      }
    },
    "button": {
      "name": "Button Card (Native)",
      "description": "Built-in simple button card",
      "domains": ["*"],
      "keywords": ["button", "native", "builtin", "simple"],
      "example": {
        "type": "button",
        "entity": "light.bedroom",
        "name": "Bedroom Light",
        "icon": "mdi:lightbulb",
        "show_state": true,
        "tap_action": {
          "action": "toggle"
        }
      },
      "schema": {
        "entity": "required - Entity ID",
        "name": "optional - Button name",
        "icon": "optional - MDI icon",
        "show_state": "optional - Show state (default: false)",
        "show_name": "optional - Show name (default: true)",
        "show_icon": "optional - Show icon (default: true)",
        "tap_action": "optional - Tap action object",
        "hold_action": "optional - Hold action object"
      }
    },
    "thermostat": {
      "name": "Thermostat Card (Native)",
      "description": "Built-in climate/thermostat control",
      "domains": ["climate"],
      "keywords": ["thermostat", "climate", "native", "hvac"],
      "example": {
        "type": "thermostat",
        "entity": "climate.living_room",
        "name": "Living Room Climate"
      },
      "schema": {
        "entity": "required - Climate entity",
        "name": "optional - Display name"
      }
    },
    "weather-forecast": {
      "name": "Weather Forecast Card (Native)",
      "description": "Built-in weather forecast display",
      "domains": ["weather"],
      "keywords": ["weather", "forecast", "native"],
      "example": {
        "type": "weather-forecast",
        "entity": "weather.home",
        "name": "Weather"
      },
      "schema": {
        "entity": "required - Weather entity",
        "name": "optional - Display name",
        "show_forecast": "optional - Show forecast (default: true)"
      }
    },
    "picture-entity": {
      "name": "Picture Entity Card (Native)",
      "description": "Built-in card displaying entity picture/camera feed with controls",
      "domains": ["camera", "*"],
      "keywords": ["picture", "camera", "image", "photo", "native"],
      "example": {
        "type": "picture-entity",
        "entity": "camera.front_door",
        "name": "Front Door Camera",
        "show_name": true,
        "show_state": true,
        "camera_view": "live"
      },
      "schema": {
        "entity": "required - Camera or entity ID",
        "name": "optional - Display name",
        "show_name": "optional - Show name overlay (default: true)",
        "show_state": "optional - Show state overlay (default: true)",
        "camera_view": "optional - Camera view mode (auto/live)",
        "aspect_ratio": "optional - Aspect ratio (e.g., 16x9, 4x3)"
      }
    }
  }
}
